{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nowplaying-app",
  "version": "0.1.3",
  "identifier": "com.ashton.nowplaying-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "NowPlaying App",
        "width": 800,
        "height": 300,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/app_icon.svg",
      "icons/icon.ico"
    ]
  }
}
